{
  "name": "klerk",
  "version": "0.1.0",
  "private": true,
  "description": "AI document processing MVP for Klerk",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "ts-node src/main.ts",
    "demo": "ts-node src/demo.ts",
    "ocr": "ts-node src/cli/ocr.ts",
    "classify": "ts-node src/cli/classify.ts",
    "extract": "ts-node src/cli/extract.ts",
    "process": "ts-node src/cli/process.ts",
    "persist": "ts-node src/cli/persist.ts",
    "process-file": "ts-node src/cli/process-file.ts",
    "get-document": "ts-node src/cli/get-document.ts",
    "test:docs": "ts-node tests/DocumentService.test.ts",
    "test:regression": "ts-node tests/SupplierInvoiceExtractor.regression.test.ts",
    "test": "ts-node tests/DocumentService.test.ts && ts-node tests/SupplierInvoiceExtractor.regression.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "dotenv": "^16.4.1",
    "express": "^4.21.1",
    "googleapis": "^173.0.0",
    "multer": "^1.4.0",
    "pg": "^8.22.0",
    "pg-boss": "^12.25.1",
    "pino": "^9.1.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
